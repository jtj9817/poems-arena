{
  "name": "@sanctuary/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "echo 'No build step — Bun runs TypeScript natively'",
    "db:backfill": "bun --env-file=../../.env run src/db/backfill.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm db:backfill && drizzle-kit migrate",
    "db:push": "pnpm db:backfill && drizzle-kit push",
    "db:seed": "bun --env-file=../../.env run src/db/seed.ts",
    "test": "bun --env-file=../../.env test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@libsql/client": "^0.14.0",
    "@sanctuary/db": "workspace:*",
    "@sanctuary/shared": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.12.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.6",
    "typescript": "~5.8.3"
  }
}
