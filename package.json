{
  "name": "poems-arena",
  "private": true,
  "version": "1.4",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @sanctuary/api dev\" \"pnpm --filter @sanctuary/web dev\"",
    "build": "pnpm --filter @sanctuary/shared build && pnpm --filter @sanctuary/web build && pnpm --filter @sanctuary/api build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . \"!**/*.md\"",
    "format:check": "prettier --check . \"!**/*.md\"",
    "coverage:phase4": "node scripts/check-phase4-coverage-gate.mjs",
    "quality:phase4": "pnpm run coverage:phase4 && pnpm lint && pnpm format:check",
    "test": "pnpm -r --if-present test",
    "version:minor": "bun scripts/bump-version.ts --minor",
    "version:major": "bun scripts/bump-version.ts --major"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ],
    "overrides": {
      "esbuild": "^0.25.0",
      "rollup": ">=4.59.0",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.0"
    }
  }
}
