# @sanctuary/etl — required environment variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored; never commit real credentials.

# ── Database (LibSQL / Turso) ─────────────────────────────────────────────────

# Production / development Turso database URL.
# Format: libsql://<db-name>-<account>.turso.io
# Use "file:./local.db" for a local SQLite file during development.
LIBSQL_URL=libsql://your-db.turso.io

# Auth token for the Turso database (leave blank for local file-backed DBs).
LIBSQL_AUTH_TOKEN=

# ── AI Verification (Anthropic) ──────────────────────────────────────────────
# Required by fix-long-poems.ts to verify split poem boundaries via Claude Haiku.
ANTHROPIC_API_KEY=

# ── CLI defaults (override via flags; documented here for reference) ──────────
#
# --input-dir   default: packages/scraper/data/raw
# --work-dir    default: packages/etl/data
# --stage       default: all  (clean | dedup | tag | load | all)
# --dry-run     default: false
# --limit       default: (none — processes all poems)
# --include-non-pd  default: false (public-domain only)
